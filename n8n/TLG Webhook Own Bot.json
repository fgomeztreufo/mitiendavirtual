      "parameters": {
        "jsCode": "const profile = $input.first().json || {};\n\nconst rawPlan = profile.plan_type ? String(profile.plan_type).toLowerCase() : 'free';\n\nlet plan = 'free';\nif (rawPlan.includes('basi') || rawPlan.includes('emprend')) plan = 'basic';\nelse if (rawPlan.includes('pro') || rawPlan.includes('crecimiento')) plan = 'pro';\nelse if (rawPlan.includes('full') || rawPlan.includes('complet')) plan = 'full';\n\nconst ctx = $('Preparar contexto').first().json;\n\nreturn [{ json: {\n  query: ctx.query,\n  chat_id: ctx.chat_id,\n  username: ctx.username,\n  user_id: ctx.user_id,\n  instance_id: ctx.instance_id,\n  plan\n} }];"
      },
