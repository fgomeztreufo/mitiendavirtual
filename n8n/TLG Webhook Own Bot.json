        "jsCode": "// Extraer user_id de la instancia y preparar datos para el agente\nconst instance = $input.first().json || {};\nconst userId = instance.user_id;\nconst instanceId = $('Extraer datos').first().json.instance_id;\nconst chatId = $('Extraer datos').first().json.chat_id;\nconst text = $('Extraer datos').first().json.text;\nconst username = $('Extraer datos').first().json.username;\n\nreturn [{ json: {\n  user_id: userId,\n  instance_id: instanceId,\n  chat_id: chatId,\n  query: text,\n  username\n} }];"
