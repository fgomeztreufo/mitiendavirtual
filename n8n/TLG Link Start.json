        }
      }
    },
    {
      "parameters": {
        "functionCode": "// Genera token único y prepara payload para INSERT en Supabase\nconst userResp = items[0].json;\nconst userBody = userResp && (userResp.body || userResp) || {};\nconst userId = userBody.id || (userBody.user && userBody.user.id) || null;\nif (!userId) throw new Error('Invalid session or user not found');\nconst randomHex = (size) => Array.from({ length: size }, () => Math.floor(Math.random() * 16).toString(16)).join('');\nconst linkToken = `${randomHex(48)}${Date.now().toString(16)}`;\nconst expiresAt = new Date(Date.now() + 10*60*1000).toISOString();\nitems[0].json = { user_id: userId, linkToken, expiresAt };\nreturn items;"
      },
      "id": "95ebf4ed-a128-4380-acbd-72347ebf84e0",
