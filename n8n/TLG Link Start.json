      "parameters": {
        "url": "=https://iesmzunoepfwkxilvxdv.supabase.co/auth/v1/user",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$json.user_token}}"
            }
          ]
        },
        "options": {}
