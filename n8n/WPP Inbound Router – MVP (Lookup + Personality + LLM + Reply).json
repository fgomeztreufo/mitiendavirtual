      "parameters": {
        "functionCode": "const msg = $node['Enriquecer + filtrar eco'].json;\nconst p = items[0].json;\n\nlet rows = [];\nif (Array.isArray(p)) {\n  rows = p;\n} else if (p && typeof p === 'object' && Object.keys(p).length > 0) {\n  rows = [p];\n}\n\nconst personality = rows.length > 0 ? rows[0] : {};\nconst systemPrompt = personality.bot_prompt || personality.system_prompt || personality.personality || 'Eres un asistente conciso y amable en español que ayuda a los clientes de una tienda online. Responde brevemente.';\n\nitems[0].json = {\n  ...msg,\n  _system_prompt: systemPrompt,\n  _ai_name: personality.ai_name || null,\n  _ai_tone: personality.ai_tone || null,\n  _biz_name: personality.biz_name || null,\n  _reply_public: personality.reply_public || null\n};\nreturn items;\n"
