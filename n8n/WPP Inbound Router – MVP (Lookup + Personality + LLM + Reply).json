    {
      "parameters": {
        "functionCode": "const prev = $node['Parsear mensaje'].json;\nconst resp = items[0].json;\n\nlet rows = [];\nif (Array.isArray(resp)) {\n  rows = resp;\n} else if (resp && Array.isArray(resp.body)) {\n  rows = resp.body;\n} else if (resp && resp.phone_number_id) {\n  rows = [resp];\n} else if (resp && typeof resp === 'object' && Object.keys(resp).length > 0) {\n  rows = [resp];\n}\n\nif (!rows || rows.length === 0) {\n  items[0].json = { _routed: false, _reason: 'no_connection', ...prev };\n  return items;\n}\n\nconst conn = rows[0];\n\n// Filtrar eco (el negocio se envía a sí mismo)\nconst bizNumber = (conn.display_phone_number || '').replace(/\\D/g, '');\nconst fromNumber = (prev._from || '').replace(/\\D/g, '');\nif (bizNumber && fromNumber && bizNumber === fromNumber) {\n  items[0].json = { _routed: false, _reason: 'echo', ...prev };\n  return items;\n}\n\nitems[0].json = {\n  _routed: true,\n  _user_id: conn.user_id,\n  _instance_id: conn.instance_id,\n  _access_token: conn.access_token,\n  _phone_number_id: prev._phone_number_id,\n  _from: prev._from,\n  _message_text: prev._message_text,\n  _message_id: prev._message_id,\n  _waba_id: prev._waba_id,\n  _display_phone_number: conn.display_phone_number || null\n};\nreturn items;\n"
      },
