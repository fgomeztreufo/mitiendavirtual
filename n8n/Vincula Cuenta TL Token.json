        "method": "POST",
        "url": "=https://api.telegram.org/bot{{ $env.TELEGRAM_BOT_TOKEN }}/sendMessage",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"chat_id\": \"{{ $('Vincular Cuenta Token').item.json.inicio.body.message.chat.id }}\", \"text\": \"✅ ¡Tu cuenta de MiTiendaVirtual fue vinculada exitosamente! Recibirás notificaciones aquí.\"}",
        "options": {}
      },
      "id": "79e28414-05fb-4f20-828c-5047b421db79",
      "name": "Enviar éxito",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        512,
        560
      ]
    },
    {
      "parameters": {
        "functionCode": "// En n8n, 'items' representa todos los elementos que llegan al nodo\n// Si el nodo anterior devuelve el array que mostraste, los datos están en items[0].json\n\nconst rows = items; // El array de objetos que mostraste\nconst chatId = $node['¿Trae token?'].json.chat_id;\nconst username = $node['¿Trae token?'].json.username;\n\n// 1. Validar si el array está vacío\nif (!rows || rows.length === 0) {\n  return [{ json: { \n    is_valid: false, \n    chat_id: chatId, \n    username,\n    error_msg: '⚠️ El enlace no es válido o ya expiró. Genera uno nuevo desde la app.' \n  } }];\n}\n\nconst tokenRow = rows[0].json; // Accedemos a la data del primer elemento\nconst now = new Date();\nconst expirationDate = new Date(tokenRow.expires_at);\n\n// 2. Validar expiración y si ya fue usado\nconst expired = tokenRow.expires_at && expirationDate <= now;\nconst alreadyUsed = tokenRow.used === true;\n\nlet errorMsg = null;\nif (expired) {\n  errorMsg = '⚠️ El enlace expiró. Genera uno nuevo desde la app.';\n} else if (alreadyUsed) {\n  errorMsg = '⚠️ Este enlace ya fue utilizado.';\n}\n\nreturn [{ json: {\n  is_valid: !expired && !alreadyUsed,\n  error_msg: errorMsg,\n  chat_id: chatId, \n  username, \n  tokenRow\n} }];"
      },
