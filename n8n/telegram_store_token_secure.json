        "jsonBody": "={\n  \"p_user_id\": \"{{$json.user_id || $json.body.user_id}}\",\n  \"p_instance_id\": \"{{$json.body.instance_id}}\",\n  \"p_provider\": \"telegram\",\n  \"p_credential_type\": \"bot_token\",\n  \"p_credential_value_text\": \"{{$json.body.bot_token}}\",\n  \"p_encrypt_key\": \"{{$env.SUPABASE_ENCRYPT_KEY}}\"\n}",
        "options": {
