        "functionCode": "// Validate Authorization: Bearer <token> with Supabase and expose user_id\nconst headers = items[0].json.headers || {};\nconst authHeader = headers.authorization || headers.Authorization || '';\nconst token = (typeof authHeader === 'string') ? (authHeader.split(' ')[1] || '') : '';\nif (!token) throw new Error('Missing Authorization token');\nconst supabaseUrl = process.env.SUPABASE_URL;\nif (!supabaseUrl) throw new Error('Missing SUPABASE_URL in env');\nconst userResp = await this.helpers.request({\n  method: 'GET',\n  uri: supabaseUrl.replace(/\/$/, '') + '/auth/v1/user',\n  headers: { Authorization: 'Bearer ' + token },\n  json: true\n});\nconst userId = userResp && (userResp.id || (userResp.user && userResp.user.id));\nif (!userId) throw new Error('Invalid session or user not found');\nitems[0].json.user_id = userId;\nitems[0].json.user_token = token;\nreturn items;"
      },
      "id": "2b3c4d5e-0000-4000-8000-000000000002",
      "name": "Validar sesión (Bearer)",
