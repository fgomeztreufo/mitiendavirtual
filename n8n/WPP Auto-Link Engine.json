        "respondWith": "json",
        "responseBody": "{\n  \"success\": false,\n  \"message\": \"El número telefónico no se encuentra registrado bajo ninguna cuenta comercial de Meta vinculada a nuestra plataforma.\"\n}",
        "options": {}
      },
      "id": "b3e218fd-d940-4cae-9274-124cfb92d6e4",
      "name": "Respond 404 Error",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1600, 480]
    }
  ],
