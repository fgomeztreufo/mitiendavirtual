      "parameters": {
        "jsCode": "const video = $input.first().json;\nconst guion = $('Merge Guion + Persona').first().json;\nconst persona = $('Persona Config').first().json;\n\nreturn [{\n  json: {\n    video_url: video.video_url,\n    gancho: guion.gancho,\n    cuerpo: guion.cuerpo,\n    cta: guion.cta,\n    hashtags: guion.hashtags,\n    titulo_post: guion.titulo_post,\n    ig_business_account_id: persona.ig_business_account_id,\n    ig_access_token: persona.ig_access_token\n  }\n}];"
