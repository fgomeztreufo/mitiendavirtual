    {
      "parameters": {
        "jsCode": "const results = $input.first().json;\nconst persona = $('Persona Config').first().json;\nconst guion = $('Merge Guion + Persona').first().json;\n\nreturn [{\n  json: {\n    timestamp: new Date().toISOString(),\n    influencer: persona.persona_nombre,\n    contenido: {\n      titulo: guion.titulo_post,\n      gancho: guion.gancho\n    },\n    publicacion: results\n  }\n}];"
